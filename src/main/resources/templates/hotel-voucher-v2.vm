<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>Hotel Booking Confirmation</title>
    <style>
        @page {
            size: A4;
            margin: 18mm;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
            font-size: 10.5pt;
            color: #1a1a2e;
            line-height: 1.5;
            background: #fff;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .letterpad-header {
            text-align: center;
            padding-bottom: 14px;
            border-bottom: 2px solid #1a1a2e;
            margin-bottom: 16px;
        }

        .letterpad-title {
            font-size: 22pt;
            font-weight: 700;
            letter-spacing: 3px;
            color: #1a1a2e;
            text-transform: uppercase;
        }

        .letterpad-subtitle {
            font-size: 9pt;
            color: #6c757d;
            margin-top: 2px;
            letter-spacing: 1px;
        }

        .letterpad-contact {
            margin-top: 8px;
            font-size: 9pt;
            color: #495057;
        }

        .letterpad-contact span {
            margin: 0 12px;
        }

        .letterpad-gst {
            font-size: 8.5pt;
            color: #6c757d;
            margin-top: 4px;
            font-family: 'Courier New', monospace;
        }

        .highlight-bar {
            background: #1a1a2e;
            color: #fff;
            padding: 16px 22px;
            margin-bottom: 12px;
        }

        .highlight-hotel {
            font-size: 18pt;
            font-weight: 800;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .highlight-address {
            font-size: 9.5pt;
            color: #adb5bd;
            margin-bottom: 12px;
        }

        .highlight-dates-row {
            width: 100%;
        }

        .highlight-dates {
            float: left;
        }

        .date-block {
            display: inline-block;
            text-align: center;
            vertical-align: middle;
            margin: 0 15px;
        }

        .date-block .label {
            font-size: 8pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #adb5bd;
            margin-bottom: 4px;
        }

        .date-block .value {
            font-size: 14pt;
            font-weight: 700;
        }

        .date-block .time {
            font-size: 9pt;
            color: #adb5bd;
            margin-top: 2px;
        }

        .highlight-arrow {
            display: inline-block;
            font-size: 20pt;
            color: #adb5bd;
            vertical-align: middle;
            padding-top: 14px;
            margin: 0 10px;
        }

        .highlight-nights {
            float: right;
            text-align: right;
            font-size: 10pt;
            color: #adb5bd;
        }

        .highlight-nights strong {
            color: #fff;
            font-size: 16pt;
            display: block;
        }

        .clearfix {
            clear: both;
        }

        .guest-strip {
            background: #f8f9fa;
            border-left: 4px solid #1a1a2e;
            padding: 10px 18px;
            margin-bottom: 14px;
        }

        .guest-strip .label {
            display: inline-block;
            font-size: 9pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #6c757d;
            margin-right: 12px;
        }

        .guest-strip .names {
            display: inline-block;
            font-size: 12pt;
            font-weight: 700;
            color: #1a1a2e;
        }

        .booking-meta {
            padding: 8px 0;
            margin-bottom: 10px;
        }

        .booking-title {
            float: left;
            font-size: 14pt;
            font-weight: 800;
            color: #1a1a2e;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .booking-id {
            float: right;
            font-size: 10pt;
            color: #495057;
            text-align: right;
        }

        .booking-id strong {
            color: #1a1a2e;
            font-family: 'Courier New', monospace;
        }

        .form-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
            font-size: 10pt;
        }

        .form-table td {
            padding: 6px 10px;
            vertical-align: top;
        }

        .form-label {
            width: 22%;
            font-weight: 700;
            color: #495057;
            font-size: 9pt;
            text-align: right;
            padding-right: 10px;
        }

        .form-value {
            width: 28%;
            font-weight: 600;
            color: #1a1a2e;
            border-bottom: 1px solid #dee2e6;
        }

        .form-value-wide {
            width: 50%;
            font-weight: 600;
            color: #1a1a2e;
            border-bottom: 1px solid #dee2e6;
        }

        .form-table tr:nth-child(odd) {
            background: #fafbfc;
        }

        .info-box {
            background: #f8f9fa;
            border-left: 3px solid #1a1a2e;
            padding: 10px 14px;
            margin-bottom: 10px;
            font-size: 9.5pt;
            color: #495057;
            line-height: 1.5;
        }

        .info-box strong {
            color: #1a1a2e;
        }

        .ref-row {
            text-align: center;
            font-size: 9pt;
            color: #6c757d;
            margin: 8px 0;
            font-family: 'Courier New', monospace;
        }

        .remarks {
            border: 1px solid #ced4da;
            padding: 12px 16px;
            margin: 12px 0;
            background: #fff;
        }

        .remarks-title {
            font-size: 10pt;
            font-weight: 700;
            color: #1a1a2e;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            padding-bottom: 6px;
            border-bottom: 1px solid #dee2e6;
        }

        .remarks div {
            font-size: 9.5pt;
            color: #495057;
            margin-bottom: 6px;
            line-height: 1.5;
        }

        .remarks div strong {
            color: #1a1a2e;
        }

        .notes-box {
            border: 1px solid #ced4da;
            margin-top: 12px;
        }

        .notes-title {
            background: #1a1a2e;
            color: #fff;
            padding: 8px 16px;
            font-size: 9pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .notes-list {
            list-style: none;
            padding: 10px 16px;
            margin: 0;
            background: #fafbfc;
        }

        .notes-list li {
            position: relative;
            padding-left: 16px;
            margin-bottom: 6px;
            font-size: 9.5pt;
            color: #495057;
            line-height: 1.5;
        }

        .notes-list li::before {
            content: '\2022';
            position: absolute;
            left: 0;
            top: 0;
            color: #1a1a2e;
            font-weight: 700;
            font-size: 12pt;
        }

        .notes-list li strong {
            color: #1a1a2e;
        }

        .footer-bar {
            margin-top: 16px;
            border-top: 1px solid #ced4da;
            padding-top: 10px;
            font-size: 8pt;
            color: #6c757d;
        }

        .footer-left {
            float: left;
            max-width: 60%;
        }

        .footer-right {
            float: right;
            text-align: right;
        }

        .footer-gst {
            font-family: 'Courier New', monospace;
            color: #495057;
        }

        .page-wrapper {
            max-width: 210mm;
            margin: 0 auto;
            padding: 10mm;
        }
    </style>
</head>
<body>

<div class="page-wrapper">

    <!-- LETTERPAD HEADER -->
    <div class="letterpad-header">
        <div class="letterpad-title">Friendly Wings Travel</div>
        <div class="letterpad-subtitle">International &amp; Domestic Hotel Bookings</div>
        <div class="letterpad-contact">
            <span>&#9993; thamizh@friendlywings.com</span>
            <span>&#9742; 8098597634, 9488493370</span>
        </div>
        <div class="letterpad-gst">GSTIN: 33BVWPT7026F1Z3</div>
    </div>

    <!-- HIGHLIGHT BAR: HOTEL + DATES -->
    <div class="highlight-bar">
        <div class="highlight-hotel">$!hotelName</div>
        <div class="highlight-address">$!address</div>
        <div class="highlight-dates-row">
            <div class="highlight-dates">
                <div class="date-block">
                    <div class="label">Check In</div>
                    <div class="value">$!checkIn</div>
                    #if($checkInTime && $checkInTime != "")
                    <div class="time">$checkInTime</div>
                    #end
                </div>
                <div class="highlight-arrow">&#8594;</div>
                <div class="date-block">
                    <div class="label">Check Out</div>
                    <div class="value">$!checkOut</div>
                    #if($checkOutTime && $checkOutTime != "")
                    <div class="time">$checkOutTime</div>
                    #end
                </div>
            </div>
            #if($nights && $nights != "")
            <div class="highlight-nights">
                <strong>$nights</strong>
                Nights
            </div>
            #end
            <div class="clearfix"></div>
        </div>
    </div>

    <!-- GUEST LIST STRIP -->
    #if($guestList && $guestList != "")
    <div class="guest-strip">
        <div class="label">Guests</div>
        <div class="names">$guestList</div>
    </div>
    #end

    <!-- BOOKING META -->
    <div class="booking-meta">
        <div class="booking-title">Booking Confirmation</div>
        <div class="booking-id">
            #if($bookingId && $bookingId != "")Booking ID: <strong>$bookingId</strong>#end
            #if($bookingRef && $bookingRef != "")&nbsp;|&nbsp; Ref: <strong>$bookingRef</strong>#end
        </div>
        <div class="clearfix"></div>
    </div>

    <!-- FORM TABLE -->
    <table class="form-table">
        <tr>
            <td class="form-label">Client :</td>
            <td class="form-value">$!client</td>
            <td class="form-label">Member ID :</td>
            <td class="form-value">$!memberId</td>
        </tr>
        <tr>
            <td class="form-label">Country :</td>
            <td class="form-value">$!countryOfResidence</td>
            <td class="form-label">Property :</td>
            <td class="form-value">$!property</td>
        </tr>
        <tr>
            <td class="form-label">Rooms :</td>
            <td class="form-value">$!rooms</td>
            <td class="form-label">Room Type :</td>
            <td class="form-value">$!roomType</td>
        </tr>
        <tr>
            <td class="form-label">Adults :</td>
            <td class="form-value">$!adults</td>
            <td class="form-label">Children :</td>
            <td class="form-value">$!children</td>
        </tr>
        <tr>
            <td class="form-label">Extra Beds :</td>
            <td class="form-value">$!extraBeds</td>
            <td class="form-label">Meals :</td>
            <td class="form-value">$!mealsIncluded</td>
        </tr>
        <tr>
            <td class="form-label">Promotion :</td>
            <td class="form-value">$!promotion</td>
            <td class="form-label">Property Contact :</td>
            <td class="form-value">$!propertyContactNumber</td>
        </tr>
        <tr>
            <td class="form-label">Payment :</td>
            <td class="form-value">$!paymentMethod</td>
            <td class="form-label">Card :</td>
            <td class="form-value">$!cardNo</td>
        </tr>
    </table>

    <!-- INFO BOXES -->
    #if($cancellationPolicy && $cancellationPolicy != "")
    <div class="info-box">
        <strong>Cancellation Policy:</strong> $cancellationPolicy
    </div>
    #end

    #if($benefitsIncluded && $benefitsIncluded != "")
    <div class="info-box">
        <strong>Benefits Included:</strong> $benefitsIncluded
    </div>
    #end

    <!-- REF ROW -->
    #if($guestRef && $guestRef != "")
    <div class="ref-row">Reference # for Guest: $guestRef</div>
    #end

    <!-- REMARKS -->
    #if($remarks && $remarks != "")
    <div class="remarks">
        <div class="remarks-title">Remarks</div>
        <div>$remarks</div>
    </div>
    #end

    <!-- NOTES -->
    <div class="notes-box">
        <div class="notes-title">Important Notes</div>
        <ul class="notes-list">
            <li><strong>IMPORTANT:</strong> At check-in, you must present the credit card used to make this booking and a valid photo ID with the same name.</li>
            <li>All rooms are guaranteed on the day of arrival. In the case of a no-show, your room(s) will be released and cancellation charges may apply.</li>
            <li>In cases where Breakfast is included with the room rate, certain hotels may charge extra for children travelling with parents.</li>
            <li>Early check-in and late checkout are subject to hotel availability.</li>
        </ul>
    </div>

    <!-- FOOTER -->
    <div class="footer-bar">
        <div class="footer-left">
            This is a computer-generated voucher and does not require a signature.<br />
            For any assistance, contact us at thamizh@friendlywings.com or call 8098597634, 9488493370
        </div>
        <div class="footer-right">
            <div class="footer-gst">GSTIN: 33BVWPT7026F1Z3</div>
        </div>
        <div class="clearfix"></div>
    </div>

</div>

</body>
</html>
